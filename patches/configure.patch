diff --git a/unix/configure b/unix/configure
index 181c64e..117906c 100644
--- a/unix/configure
+++ b/unix/configure
@@ -24,6 +24,15 @@ LN="ln -s"
 
 CFLAGS_OPT=''
 
+# External flags can be set via environment variables:
+# CFLAGS_EXTRA, LDFLAGS_EXTRA, LIBS_EXTRA
+# These will be used in configure tests and appended to final flags
+
+# Apply external flags to configure tests
+[ -n "${CFLAGS_EXTRA}" ] && CFLAGS="${CFLAGS} ${CFLAGS_EXTRA}"
+[ -n "${LDFLAGS_EXTRA}" ] && LFLAGS1="${LFLAGS1} ${LDFLAGS_EXTRA}"
+[ -n "${LIBS_EXTRA}" ] && LFLAGS2="${LFLAGS2} ${LIBS_EXTRA}"
+
 # bzip2
 IZ_BZIP2=${3-}
 CFLAGS_BZ=''
@@ -513,17 +522,18 @@ for func in rmdir strchr strrchr rename mktemp mktime mkstemp
 do
   echo Check for $func
   echo "int main(){ $func(); return 0; }" > conftest.c
-  $CC $BFLAG -o conftest conftest.c >/dev/null 2>/dev/null
-# glibc-based systems do not need this
-# [ $? -ne 0 ] && CFLAGS="${CFLAGS} -DNO_`echo $func | tr '[a-z]' '[A-Z]'`"
+  $CC $BFLAG -Wno-implicit-function-declaration -o conftest conftest.c >/dev/null 2>/dev/null
+  [ $? -ne 0 ] && CFLAGS="${CFLAGS} -DNO_`echo $func | tr '[a-z]' '[A-Z]'`"
 done
 
 
 echo Check for memset
-echo "int main(){ char k; memset(&k,0,0); return 0; }" > conftest.c
+cat > conftest.c << _EOF_
+#include <string.h>
+int main(){ char k; memset(&k,0,0); return 0; }
+_EOF_
 $CC -o conftest conftest.c >/dev/null 2>/dev/null
-# glibc-based systems do not need this
-# [ $? -ne 0 ] && CFLAGS="${CFLAGS} -DZMEM"
+[ $? -ne 0 ] && CFLAGS="${CFLAGS} -DZMEM"
 
 
 echo Check for memmove
@@ -553,12 +563,12 @@ main()
 }
 _EOF_
 $CC $CFLAGS -c conftest.c >/dev/null 2>/dev/null
-# glibc-based systems do not need this
-# [ $? -ne 0 ] && CFLAGS="${CFLAGS} -DNO_ERRNO"
+[ $? -ne 0 ] && CFLAGS="${CFLAGS} -DNO_ERRNO"
 
 
 echo Check for directory libraries
 cat > conftest.c << _EOF_
+#include <dirent.h>
 int main() { return closedir(opendir(".")); }
 _EOF_
 
@@ -570,8 +580,7 @@ if [ $? -ne 0 ]; then
     $CC -o conftest conftest.c -l$lib >/dev/null 2>/dev/null
     [ $? -eq 0 ] && OPT=-l$lib && break
   done
-  # glibc-based systems do not need this
-  if true; then
+  if [ ${OPT} ]; then
     LFLAGS2="${LFLAGS2} ${OPT}"
   else
     CFLAGS="${CFLAGS} -DNO_DIR"
@@ -582,7 +591,10 @@ fi
 # Dynix/ptx 1.3 needed this
 
 echo Check for readlink
-echo "int main(){ return readlink(); }" > conftest.c
+cat > conftest.c << _EOF_
+#include <unistd.h>
+int main(){ return readlink(); }
+_EOF_
 $CC -o conftest conftest.c >/dev/null 2>/dev/null
 if [ $? -ne 0 ]; then
   $CC -o conftest conftest.c -lseq >/dev/null 2>/dev/null
@@ -633,8 +645,7 @@ main()
 }
 _EOF_
 $CC ${CFLAGS} -c conftest.c > /dev/null 2>/dev/null
-# glibc-based systems do not need this
-# [ $? -ne 0 ] && CFLAGS="${CFLAGS} -DNO_VALLOC"
+[ $? -ne 0 ] && CFLAGS="${CFLAGS} -DNO_VALLOC"
 
 
 echo Check for /usr/local/bin and /usr/local/man
